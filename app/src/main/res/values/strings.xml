    <string name="onboarding_capture_title">Capture &amp; Save</string>
    <string name="onboarding_capture_desc">Tap the camera button in the bottom-right to capture the current frame and save it instantly.</string>

    <string name="onboarding_mute_title">Mute Audio</string>
    <string name="onboarding_mute_desc">Mute video playback and remove audio from exported motion photos.</string>

    <string name="onboarding_motion_title">Motion Photo</string>
    <string name="onboarding_motion_desc">Enable this to export a Google Motion Photo — a still image with a short video clip embedded around the captured frame.</string>

    <string name="onboarding_metadata_title">Preserve Metadata</string>
    <string name="onboarding_metadata_desc">Keep the original video\'s EXIF metadata (date, location, camera info) in the exported image.</string>

    <string name="onboarding_format_title">Export Format</string>
    <string name="onboarding_format_desc">Tap to cycle through formats: JPEG, PNG, WEBP, HEIF, AVIF. Each has different quality and compatibility trade-offs.</string>

    <string name="onboarding_slider_title">Seek &amp; Fine Scrubbing</string>
    <string name="onboarding_slider_desc">Drag the slider to seek. Swipe UP while dragging to enter fine scrubbing mode for frame-precise control.</string>

    <string name="onboarding_gestures_title">Video Gestures</string>
    <string name="onboarding_gestures_desc">Tap the video to play/pause. Pinch to zoom (up to 3x). When zoomed, drag to pan, or double-tap to reset zoom.</string>

    <string name="onboarding_frame_step_title">Frame Step</string>
    <string name="onboarding_frame_step_desc">Use the ‹‹ and ›› buttons to step backward or forward one frame at a time for precise frame selection.</string>

